# Copy to `.env.local` at this repository root (same folder as package.json `name`: pg-application).
# Both `apps/web` and `apps/api` load this file — do not duplicate secrets under apps/*.
#
# After changing this file, restart `npm run dev` (Next only picks up env changes on restart).

# --- Next.js (public + server-only) ---
# Optional: Google Places on the apply form.
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# Admin portal + Supabase client (NEXT_PUBLIC_* are safe for the browser).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- API (server-only; never use NEXT_PUBLIC_ for these) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
RESEND_FROM=noreply@portfolioguardian.com.au
APPLICATION_NOTIFICATION_EMAIL=applications@portfolioguardian.com.au
# Admin links in notification emails. For local dev, localhost is fine.
# On Vercel, either set this to your production admin URL (e.g. https://yourdomain.com/admin),
# or omit it: the app will use https://{VERCEL_URL}/admin automatically.
ADMIN_APP_URL=http://localhost:3000/admin
# Optional: canonical public site (used if ADMIN_APP_URL is missing or still localhost).
# PUBLIC_SITE_URL=https://www.portfolioguardian.com.au
PORT=4000

# Optional (e.g. some Supabase tooling).
# SUPABASE_JWT_SECRET=
