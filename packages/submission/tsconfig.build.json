{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@pg/shared": ["../shared/dist/index.d.ts"],
      "@pg/shared/*": ["../shared/dist/*"],
      "@pg/submission": ["./src/index.ts"],
      "@pg/submission/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"]
}
