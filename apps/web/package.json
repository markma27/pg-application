{
  "name": "@pg/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:tls": "node --use-system-ca ../../node_modules/next/dist/bin/next dev --webpack",
    "build": "cd ../.. && npm run build -w @pg/shared && npm run build -w @pg/submission && npm run build:next -w @pg/web",
    "build:next": "next build --webpack && node ./scripts/prune-nft-trace.mjs",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@pg/shared": "file:../../packages/shared",
    "@pg/submission": "file:../../packages/submission",
    "@radix-ui/react-slot": "^1.3.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "rate-limiter-flexible": "^11.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "resend": "^6.17.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@fontsource/montserrat": "^5.2.8",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}
