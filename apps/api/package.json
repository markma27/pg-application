{
  "name": "@pg/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:tls": "node --use-system-ca ../../node_modules/tsx/dist/cli.mjs watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx dist/apps/api/src/server.js",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@pg/shared": "0.1.0",
    "@pg/submission": "0.1.0",
    "cors": "latest",
    "express": "latest",
    "express-rate-limit": "^8.3.1",
    "tsx": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/cors": "latest",
    "@types/express": "latest",
    "typescript": "latest"
  }
}
